# Copy this file to `.env` for local dev, or add these in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.
#
# The key is ONLY read by the serverless function in /api — it is never sent to
# or exposed in the browser.

# Required — a free key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional — override the primary model. Defaults to llama-3.3-70b-versatile.
# Tip: llama-3.1-8b-instant is faster and has a much higher free daily limit.
# GROQ_MODEL=llama-3.3-70b-versatile

# Recommended — a free key from https://aistudio.google.com/apikey
# Used automatically as the fallback when Groq is rate-limited (429). Gemini's
# free tier allows far more tokens per minute than Groq's, so this makes the app
# much more reliable under load. Leave it unset to fall back to a smaller Groq
# model instead.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — override the Gemini fallback model. Defaults to gemini-flash-latest
# (an alias that always tracks the current flash model, so it won't stop working
# when Google retires a pinned version).
# GEMINI_MODEL=gemini-flash-latest

# Optional — smaller Groq model used as the fallback ONLY when no GEMINI_API_KEY
# is set. Defaults to llama-3.1-8b-instant.
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
