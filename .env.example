# Copy this file to `.env` for local dev, or add these in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.
#
# The key is ONLY read by the serverless function in /api — it is never sent to
# or exposed in the browser.

# Required — a free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — override the model. Defaults to gemini-flash-lite-latest, which has
# a generous free-tier daily limit. If your key has quota for a stronger model,
# set e.g. GEMINI_MODEL=gemini-2.5-flash.
# GEMINI_MODEL=gemini-flash-lite-latest
